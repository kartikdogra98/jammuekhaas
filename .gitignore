# ===== Dependencies =====
node_modules/
frontend/node_modules/
backend/node_modules/
.pnp
.pnp.js

# ===== Environment variables (never commit real secrets) =====
.env
.env.local
.env.development.local
.env.test.local
.env.example
.env.production.local
backend/.env
backend/.env.example

frontend/.env.production
frontend/.env.development

# ===== Build output =====
frontend/dist/
frontend/build/
backend/dist/
*.local

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Uploaded / user-generated files =====
# Keep the folder tracked (via .gitkeep) but ignore actual uploaded content
backend/uploads/*
!backend/uploads/.gitkeep

# ===== Editor / OS junk =====
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ===== Testing / coverage =====
coverage/
.nyc_output/

# ===== Vite =====
frontend/.vite/
frontend/node_modules/.vite/

# ===== Misc =====
*.tgz
*.tar.gz
.eslintcache