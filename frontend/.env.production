# Vite proxies /api to the backend in dev (see vite.config.js), so no VITE_API_URL is needed locally.
# If you deploy frontend and backend separately, set this and update src/api/axios.js baseURL accordingly.
VITE_API_URL=https://jammuekhaas.onrender.com/api

# Google OAuth Client ID (used by Google Identity Services on the login/register pages)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Razorpay public key (also returned by the backend at checkout, but handy for reference)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
